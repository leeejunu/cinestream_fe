{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://52.78.88.98:8000/api/:path*"
    },
    {
      "source": "/posters/:path*",
      "destination": "http://52.78.88.98:8000/posters/:path*"
    },
    {
      "source": "/((?!api/|posters/).*)",
      "destination": "/index.html"
    }
  ]
}

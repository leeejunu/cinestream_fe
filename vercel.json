{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://52.78.88.98:8000/api/:path*"
    },
    {
      "source": "/files/:path*",
      "destination": "http://52.78.88.98:8000/files/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "http://52.78.88.98:8000/ws/:path*"
    },
    {
      "source": "/((?!api/|files/|ws/).*)",
      "destination": "/index.html"
    }
  ]
}
